---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import Archetypes from '@/components/Archetypes.astro';
import ValueProps from '@/components/ValueProps.astro';
import FeatureCards from '@/components/FeatureCards.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import Gallery from '@/components/Gallery.astro';
import ShareProof from '@/components/ShareProof.astro';
import ExportCta from '@/components/ExportCta.astro';
import BlogTeaser from '@/components/BlogTeaser.astro';
import Footer from '@/components/Footer.astro';

// significanthobbies — landing page.
//
// Port of /src/app/page.tsx + the LandingClient inside it. Composition
// (Hero → Archetypes → ValueProps → FeatureCards → HowItWorks →
// Gallery → ShareProof → ExportCta → BlogTeaser → Footer) mirrors the
// React file 1:1 so visitors see the same vertical rhythm at cutover.
//
// Sections dropped vs. the React version (documented in README):
// - `<Nav />` — was rendered by layout.tsx, lives only on the Worker
//   for the rest of the app.
// - `<SaaSMakerTestimonialsSection />` + `<SaaSMakerChangelogSection />`
//   — React widgets, deferred until a static API integration exists.

const TITLE = 'SignificantHobbies — Your Hobby Journey';
const DESCRIPTION =
  'Map your hobby history across life phases. Discover what rekindled, what persisted, and what to explore next.';
---

<Layout title={TITLE} description={DESCRIPTION}>
  <div class="min-h-screen">
    <Hero />
    <Archetypes />
    <ValueProps />
    <FeatureCards />
    <HowItWorks />
    <Gallery />
    <ShareProof />
    <ExportCta />
    <BlogTeaser />
    <Footer />
  </div>
</Layout>
