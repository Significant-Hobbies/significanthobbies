---
import BucketListPanel from '@/components/BucketListPanel.astro';
import CommunitySamples from '@/components/CommunitySamples.astro';
import FeatureRow from '@/components/FeatureRow.astro';
import FinalCta from '@/components/FinalCta.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import Layout from '@/layouts/Layout.astro';

const TITLE = 'SignificantHobbies — Your Hobby Journey';
const DESCRIPTION =
  'Map your hobby history across life phases. Discover what rekindled, what persisted, and what to explore next.';
---

<Layout title={TITLE} description={DESCRIPTION}>
  <!-- Full-bleed scenic hero. The photo IS the design. -->
  <section class="relative flex min-h-svh flex-col justify-end overflow-hidden bg-stone-950">
    <img
      src="/hero/dawn-valley-1920.webp"
      srcset="/hero/dawn-valley-640.webp 640w, /hero/dawn-valley-1280.webp 1280w, /hero/dawn-valley-1920.webp 1920w, /hero/dawn-valley-2560.webp 2560w"
      sizes="100vw"
      alt="Misty valley at dawn"
      class="absolute inset-0 h-full w-full object-cover"
      fetchpriority="high"
    />
    <!-- Single darkening pass at the bottom for text legibility. No tint, no teal wash. -->
    <div
      class="pointer-events-none absolute inset-0"
      aria-hidden="true"
      style="background: linear-gradient(to top, rgba(12, 43, 41, 0.88) 0%, rgba(12, 43, 41, 0.4) 35%, transparent 60%);"
    />

    <div class="relative z-10 mx-auto w-full max-w-6xl px-6 pb-20 lg:px-12 lg:pb-28">
      <div class="max-w-xl">
        <h1
          class="text-4xl font-medium tracking-tight text-white sm:text-5xl lg:text-6xl"
          style="line-height: 1.1; font-family: var(--font-spectral, Georgia, serif); font-weight: 500;"
        >
          The hobbies that shaped you. The life you still want to live.
        </h1>

        <p class="mt-5 max-w-md text-base text-stone-300 sm:text-lg" style="line-height: 1.5;">
          Map every hobby from childhood to now. Commit to daily practice.
          See your life in weeks, and decide what the remaining ones are for.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href="/timeline/new"
            class="rounded-full bg-white px-6 py-2.5 text-sm font-semibold text-stone-950 no-underline transition-opacity hover:opacity-90"
          >
            Start your hobby map
          </a>
          <a
            href="/bucket-lists"
            class="rounded-full border border-white/25 px-6 py-2.5 text-sm font-medium text-white no-underline transition-colors hover:border-white/50"
          >
            Build your bucket list
          </a>
        </div>

        <p class="mt-5 text-sm text-stone-400">No sign-up required to start</p>
      </div>
    </div>
  </section>

  <FeatureRow />
  <BucketListPanel />
  <HowItWorks />
  <CommunitySamples />
  <FinalCta />
</Layout>