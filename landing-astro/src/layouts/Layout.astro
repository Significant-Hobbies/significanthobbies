---
import '@/styles/landing.css';
import '@fontsource-variable/geist';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const SITE_URL = 'https://significanthobbies.com';
// OG image lives on the Next.js Worker at /opengraph-image (Next file
// convention → dynamic JSX → PNG). Post-cutover Pages takes only `/`
// and Workers keeps every other route, so this URL still resolves.
// See README → cutover notes.
const OG_IMAGE = `${SITE_URL}/opengraph-image`;

// Mirrors the Organization JSON-LD the Next.js layout.tsx renders on
// every page. Kept verbatim so search-engine signals don't change at
// cutover.
const ORG_JSON_LD = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'SignificantHobbies',
  url: SITE_URL,
  description:
    'Map your hobby history across life phases. Discover what rekindled, what persisted, and what to explore next.',
  sameAs: [],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#059669" />
    <meta name="format-detection" content="telephone=no" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content="SignificantHobbies" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="SignificantHobbies" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />

    <link rel="canonical" href={SITE_URL} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.json" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:site_name" content="SignificantHobbies" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={OG_IMAGE} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />

    {/* ── Geist (latin) ──────────────────────────────────────────────
       Self-hosted via @fontsource-variable/geist (imported in the
       frontmatter). Astro/Vite extracts the @font-face into the page's
       CSS and serves the woff2 same-origin from /_astro/, so there is
       no external CSS fetch on the LCP path. `font-display: swap` is
       preserved by Fontsource. */}

    {/* Wire the same `--font-geist-sans` CSS var Next.js's `next/font`
       sets up, so any inline styles that reference it keep working.
       Fontsource registers the family as 'Geist Variable'. */}
    <style is:inline>
      :root {
        --font-geist-sans: 'Geist Variable', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }
      body { margin: 0; font-family: var(--font-geist-sans); }
    </style>

    <script type="application/ld+json" set:html={JSON.stringify(ORG_JSON_LD)} />
  </head>
  <body class="antialiased min-h-screen bg-amber-50 text-stone-900">
    <slot />
  </body>
</html>
