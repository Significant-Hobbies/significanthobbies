---
// Feature cards — three product-pillar cards with inline SVG
// illustrations. React version animated bars on entry via useInView +
// inline-style branching; we swap that for the CSS .scroll-reveal
// classes (animation-timeline: view()).
---

<section class="px-4 py-20" style="background: #FAFAFA;">
  <div class="mx-auto max-w-5xl">
    <div class="mb-12 text-center scroll-reveal">
      <span class="mb-3 inline-block rounded-full border border-emerald-200 bg-emerald-50 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-emerald-700">
        Why SignificantHobbies
      </span>
      <h2 class="text-3xl font-bold text-stone-900 sm:text-4xl">Everything your hobby journey needs</h2>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
      {/* Card 1 — PhaseMap */}
      <div class="scroll-reveal scroll-reveal-d1 group relative overflow-hidden rounded-2xl border border-stone-200 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-emerald-300 hover:shadow-[0_8px_32px_rgba(16,185,129,0.12)]">
        <div class="absolute inset-x-0 top-0 h-0.5 origin-left scale-x-0 bg-emerald-400 transition-transform duration-300 group-hover:scale-x-100" />
        <svg width="180" height="90" viewBox="0 0 180 90" fill="none" xmlns="http://www.w3.org/2000/svg" class="mx-auto mb-5">
          {/* Phase bands */}
          {[
            { x: 0, color: '#D1FAE5', stroke: '#10b981' },
            { x: 36, color: '#FEF3C7', stroke: '#F59E0B' },
            { x: 72, color: '#DBEAFE', stroke: '#3B82F6' },
            { x: 108, color: '#FCE7F3', stroke: '#EC4899' },
            { x: 144, color: '#EDE9FE', stroke: '#8B5CF6' },
          ].map((band) => (
            <g>
              <rect x={band.x + 2} y={20} width={32} height={50} rx={6} fill={band.color} stroke={band.stroke} stroke-width={1.5} />
              {[32, 42, 52].map((cy) => (
                <circle cx={band.x + 18} cy={cy} r={3} fill={band.stroke} opacity={0.7} />
              ))}
            </g>
          ))}
          <polyline points="18,46 54,38 90,50 126,42 162,46" stroke="#059669" stroke-width={1.5} stroke-dasharray="4 2" fill="none" opacity={0.5} />
        </svg>
        <h3 class="mb-2 text-lg font-semibold text-stone-800">Map your journey</h3>
        <p class="text-sm leading-relaxed text-stone-500">
          Build life phases from childhood to now. Add every hobby, interest, and passion along the way.
        </p>
      </div>

      {/* Card 2 — BarChart */}
      <div class="scroll-reveal scroll-reveal-d2 group relative overflow-hidden rounded-2xl border border-stone-200 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-emerald-300 hover:shadow-[0_8px_32px_rgba(16,185,129,0.12)]">
        <div class="absolute inset-x-0 top-0 h-0.5 origin-left scale-x-0 bg-emerald-400 transition-transform duration-300 group-hover:scale-x-100" />
        <svg width="160" height="90" viewBox="0 0 160 90" fill="none" xmlns="http://www.w3.org/2000/svg" class="mx-auto mb-5">
          <line x1="10" y1="78" x2="150" y2="78" stroke="#d1d5db" stroke-width="1.5" />
          {[
            { height: 48, color: '#10b981', delay: '0s' },
            { height: 64, color: '#059669', delay: '0.1s' },
            { height: 36, color: '#34d399', delay: '0.2s' },
            { height: 56, color: '#10b981', delay: '0.3s' },
            { height: 72, color: '#059669', delay: '0.4s' },
            { height: 44, color: '#34d399', delay: '0.5s' },
          ].map((bar, i) => (
            <rect
              x={10 + i * 22}
              y={78 - bar.height}
              width={16}
              height={bar.height}
              rx={3}
              fill={bar.color}
              opacity={0.85}
              style={`animation: growUp 0.6s ease-out ${bar.delay} both;`}
            />
          ))}
          <polyline
            points="18,42 40,26 62,50 84,34 106,18 128,38"
            stroke="#F59E0B"
            stroke-width={2}
            stroke-dasharray="4 2"
            fill="none"
            style="animation: fadeInUp 0.8s 0.6s ease-out both;"
          />
        </svg>
        <h3 class="mb-2 text-lg font-semibold text-stone-800">Discover your hobby personality</h3>
        <p class="text-sm leading-relaxed text-stone-500">
          See rekindled hobbies, what stuck across decades, and uncover the archetype your interests reveal.
        </p>
      </div>

      {/* Card 3 — HobbyTags */}
      <div class="scroll-reveal scroll-reveal-d3 group relative overflow-hidden rounded-2xl border border-stone-200 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-emerald-300 hover:shadow-[0_8px_32px_rgba(16,185,129,0.12)]">
        <div class="absolute inset-x-0 top-0 h-0.5 origin-left scale-x-0 bg-emerald-400 transition-transform duration-300 group-hover:scale-x-100" />
        <svg width="180" height="90" viewBox="0 0 180 90" fill="none" xmlns="http://www.w3.org/2000/svg" class="mx-auto mb-5">
          {['pottery', 'running', 'reading', 'chess', 'hiking'].map((tag, i) => {
            const x = 8 + (i % 3) * 60;
            const y = 10 + Math.floor(i / 3) * 42;
            return (
              <g style={`animation: slideInRight 0.5s ${i * 0.12}s ease-out both;`}>
                <rect x={x} y={y} width={54} height={22} rx={11} fill="#D1FAE5" stroke="#10b981" stroke-width={1.2} />
                <text x={x + 27} y={y + 14.5} text-anchor="middle" fill="#059669" font-size={9} font-weight={600}>{tag}</text>
              </g>
            );
          })}
          <text x="152" y="48" fill="#10b981" font-size="18" opacity={0.7}>→</text>
        </svg>
        <h3 class="mb-2 text-lg font-semibold text-stone-800">Share your identity artifact</h3>
        <p class="text-sm leading-relaxed text-stone-500">
          Generate a stunning card of your hobby journey — a window into who you are, ready to share anywhere.
        </p>
      </div>
    </div>
  </div>
</section>
