---
const journeyPhases = [
  {
    label: 'Childhood',
    color: 'oklch(0.72 0.13 150)',
    bg: 'oklch(0.72 0.13 150 / 0.12)',
    border: 'oklch(0.72 0.13 150 / 0.35)',
    img: '/categories/gaming-800.webp',
    hobbies: ['Lego', 'Swimming', 'Chess', 'Drawing'],
  },
  {
    label: 'Teen Years',
    color: 'oklch(0.82 0.13 88)',
    bg: 'oklch(0.82 0.13 88 / 0.12)',
    border: 'oklch(0.82 0.13 88 / 0.35)',
    img: '/categories/music-800.webp',
    hobbies: ['Guitar', 'Skateboarding', 'Video games'],
  },
  {
    label: 'College',
    color: 'oklch(0.78 0.10 200)',
    bg: 'oklch(0.78 0.10 200 / 0.12)',
    border: 'oklch(0.78 0.10 200 / 0.35)',
    img: '/categories/outdoor-800.webp',
    hobbies: ['Hiking', 'Photography', 'Coding'],
  },
  {
    label: 'Now',
    color: 'oklch(0.80 0.08 320)',
    bg: 'oklch(0.80 0.08 320 / 0.12)',
    border: 'oklch(0.80 0.08 320 / 0.35)',
    img: '/categories/culinary-800.webp',
    hobbies: ['Running', 'Cooking', 'Pottery'],
  },
];

const archetypeBars = [
  { label: 'Explorer', value: 86, color: 'oklch(0.82 0.13 88)' },
  { label: 'Maker', value: 64, color: 'oklch(0.72 0.13 150)' },
  { label: 'Athlete', value: 42, color: 'oklch(0.78 0.10 200)' },
  { label: 'Collector', value: 28, color: 'oklch(0.80 0.08 320)' },
];

const identityTags = ['Hiking', 'Photography', 'Cooking', 'Guitar', 'Pottery'];
---

<section class="bg-background px-6 py-24 lg:px-12">
  <div class="mx-auto max-w-6xl">
    <!-- Section heading -->
    <div class="mb-12 max-w-2xl">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">Features</p>
      <h2 class="text-3xl font-medium text-foreground sm:text-4xl" style="line-height: 1.1;">
        Everything you need to map your hobbies<br class="hidden sm:block" /> and find new ones
      </h2>
    </div>

    <!-- Bento grid: 3-col asymmetric -->
    <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
      <!-- ═══ Card 1 (large, 2 cols) — Map your hobby journey ═══ -->
      <div class="spotlight-card card-lift shadow-elevated md:col-span-2 overflow-hidden rounded-2xl border border-border bg-card p-6">
        <div class="mb-5 flex items-center justify-between">
          <div>
            <h3 class="text-xl font-semibold text-foreground">Map your hobby journey</h3>
            <p class="mt-1 text-sm text-muted-foreground">
              Build life phases and tag every interest you remember, even the ones you only tried once.
            </p>
          </div>
          <span class="hidden shrink-0 rounded-full bg-muted px-3 py-1 text-xs font-medium text-muted-foreground sm:inline-block">
            Timeline view
          </span>
        </div>
        <!-- Richer mock timeline with Unsplash thumbnails per phase -->
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          {
            journeyPhases.map((phase) => (
              <div class="overflow-hidden rounded-xl border border-border bg-background">
                <div class="relative h-20 overflow-hidden">
                  <img
                    src={phase.img}
                    alt={`${phase.label} hobbies`}
                    loading="lazy"
                    class="h-full w-full object-cover"
                  />
                  <div
                    class="absolute inset-0"
                    style={`background: linear-gradient(to top, ${phase.bg.replace('/ 0.12', '/ 0.55')}, transparent);`}
                  />
                  <div class="absolute bottom-1.5 left-2 flex items-center gap-1.5">
                    <div class="h-2 w-2 rounded-full" style={`background: ${phase.color}`} />
                    <span class="text-[11px] font-semibold text-foreground">{phase.label}</span>
                  </div>
                </div>
                <div class="flex flex-wrap gap-1 p-2.5">
                  {phase.hobbies.map((h) => (
                    <span
                      class="rounded-full border px-1.5 py-0.5 text-[10px] font-medium"
                      style={`background: ${phase.bg}; border-color: ${phase.border}; color: ${phase.color}`}
                    >
                      {h}
                    </span>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
        <p class="mt-4 text-center text-[11px] text-muted-foreground">
          4 phases · 13 hobbies · your story will look different
        </p>
      </div>

      <!-- ═══ Card 2 (small) — Discover your archetype ═══ -->
      <div class="spotlight-card card-lift shadow-elevated overflow-hidden rounded-2xl border border-border bg-card p-6">
        <h3 class="text-base font-semibold text-foreground">Discover your archetype</h3>
        <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">
          See what stuck across the years and what your interests say about you.
        </p>
        <!-- Visual personality card mockup -->
        <div class="mt-5 rounded-xl border border-border bg-background p-4">
          <div class="mb-3 flex items-center justify-between">
            <span class="text-xs font-medium text-muted-foreground">Your archetype</span>
            <span class="rounded-full bg-primary/15 px-2 py-0.5 text-[10px] font-semibold text-primary">
              Top match
            </span>
          </div>
          <div class="mb-4 flex items-baseline gap-2">
            <span class="font-serif text-2xl font-semibold gold-text">The Explorer</span>
          </div>
          <div class="flex flex-col gap-2.5">
            {
              archetypeBars.map((bar) => (
                <div>
                  <div class="mb-1 flex items-center justify-between text-[10px]">
                    <span class="text-muted-foreground">{bar.label}</span>
                    <span class="font-semibold text-foreground">{bar.value}%</span>
                  </div>
                  <div class="h-1.5 overflow-hidden rounded-full bg-muted">
                    <div
                      class="h-full rounded-full"
                      style={`width: ${bar.value}%; background: ${bar.color};`}
                    />
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- ═══ Card 3 (small) — Share your identity card ═══ -->
      <div class="spotlight-card card-lift shadow-elevated md:col-span-1 overflow-hidden rounded-2xl border border-border bg-card p-6">
        <h3 class="text-base font-semibold text-foreground">Share your identity card</h3>
        <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">
          Export your whole hobby journey as a card you can share anywhere.
        </p>
        <!-- Mock export card with gradient border -->
        <div class="gradient-border mt-5 p-4">
          <div class="mb-3 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="flex h-7 w-7 items-center justify-center rounded-full bg-primary text-[11px] font-bold text-primary-foreground">
                A
              </div>
              <span class="text-xs font-semibold text-foreground">@alex</span>
            </div>
            <span class="text-[10px] text-muted-foreground">5 hobbies</span>
          </div>
          <p class="mb-3 font-serif text-sm text-foreground" style="line-height: 1.3;">
            "My hobby journey, mapped."
          </p>
          <div class="flex flex-wrap gap-1.5">
            {
              identityTags.map((tag) => (
                <span class="rounded-full border border-border bg-muted px-2 py-0.5 text-[10px] font-medium text-foreground">
                  {tag}
                </span>
              ))
            }
          </div>
          <div class="mt-3 flex items-center gap-2 border-t border-border pt-3">
            <span class="rounded-md bg-primary px-2 py-1 text-[9px] font-semibold text-primary-foreground">
              Export PNG
            </span>
            <span class="rounded-md border border-border px-2 py-1 text-[9px] font-medium text-muted-foreground">
              Share link
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
