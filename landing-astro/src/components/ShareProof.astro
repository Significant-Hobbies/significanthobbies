---
// Share Proof — "Share your map — one tap away" two-up section.
// Left: copy + checklist + CTAs. Right: dark share-card preview with
// "What your friends see" context and a faux Share-via action strip.
const PHASE_COLORS = [
  { bg: '#D1FAE5', border: '#10b981', label: 'Childhood' },
  { bg: '#FEF3C7', border: '#F59E0B', label: 'Teen Years' },
  { bg: '#DBEAFE', border: '#3B82F6', label: 'College' },
  { bg: '#FCE7F3', border: '#EC4899', label: 'Early Career' },
  { bg: '#EDE9FE', border: '#8B5CF6', label: 'Now' },
];

const HOBBIES = ['guitar 🎸', 'chess ♟', 'hiking 🏔', 'reading 📚', 'pottery 🏺', 'swimming 🏊'];

const SHARE_BUTTONS = [
  { icon: '🔗', label: 'Copy link' },
  { icon: '𝕏', label: 'Twitter' },
  { icon: '💬', label: 'WhatsApp' },
];
---

<section class="px-4 py-24" style="background: linear-gradient(135deg, #FAFAF9 0%, #F0FDF4 50%, #FAFAF9 100%);">
  <div class="mx-auto max-w-5xl">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
      {/* Left: text + CTA */}
      <div class="scroll-reveal-left">
        <span class="mb-4 inline-block rounded-full border border-emerald-200 bg-emerald-50 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-emerald-700">
          Share
        </span>
        <h2 class="mb-4 text-3xl font-bold leading-tight text-stone-900 sm:text-4xl">
          Share your map —<br />
          <span class="italic text-emerald-600">one tap away</span>
        </h2>
        <p class="mb-6 text-lg text-stone-500">
          Build your hobby journey, then share a beautiful card of your whole story. Your friends see exactly what you see on the right.
        </p>
        <ul class="mb-8 space-y-2 text-sm text-stone-500">
          <li class="flex items-center gap-2">
            <span class="text-emerald-500">✓</span> Download as a PNG and post anywhere
          </li>
          <li class="flex items-center gap-2">
            <span class="text-emerald-500">✓</span> Copy a link — opens a live, interactive view
          </li>
          <li class="flex items-center gap-2">
            <span class="text-emerald-500">✓</span> One-tap share to Twitter / X or WhatsApp
          </li>
        </ul>
        <div class="flex flex-wrap gap-4">
          <a
            href="/timeline/new"
            class="animate-glow-pulse inline-flex h-11 items-center justify-center rounded-md bg-emerald-600 px-8 text-base font-medium text-white hover:bg-emerald-700"
          >
            Share your map →
          </a>
          <a
            href="/hobbies"
            class="inline-flex h-11 items-center justify-center rounded-md border border-stone-300 bg-transparent px-8 text-base font-medium text-stone-600 hover:text-stone-900"
          >
            Browse hobbies
          </a>
        </div>
        <p class="mt-4 text-sm text-stone-400">No sign-up required. Always free.</p>
      </div>

      {/* Right: dark share card preview */}
      <div class="flex flex-col items-center lg:items-end scroll-reveal-right scroll-reveal-d1">
        <div class="mb-3 flex items-center gap-2 self-stretch lg:self-end lg:max-w-sm">
          <div class="h-px flex-1 bg-stone-200" />
          <span class="shrink-0 text-[11px] font-medium uppercase tracking-widest text-stone-400">
            What your friends see
          </span>
          <div class="h-px flex-1 bg-stone-200" />
        </div>

        <div
          class="animate-float relative w-full max-w-sm overflow-hidden rounded-2xl border border-emerald-900/30 bg-slate-900 p-7 shadow-2xl"
          style="box-shadow: 0 0 40px rgba(16,185,129,0.2), 0 24px 64px rgba(0,0,0,0.3);"
        >
          {/* Shine pass */}
          <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-2xl" style="z-index: 10;">
            <div style="position: absolute; top: 0; left: -100%; width: 60%; height: 100%; background: linear-gradient(105deg, transparent 30%, rgba(255,255,255,0.06) 50%, transparent 70%); animation: shinePass 4s 1s ease-in-out infinite;" />
          </div>

          <div class="relative z-0">
            <div class="mb-1 text-xs font-semibold tracking-widest text-emerald-400 uppercase">My Hobby Journey</div>
            <div class="mb-0.5 text-lg font-bold text-white">A Life in Hobbies</div>
            <div class="mb-4 text-xs text-slate-500">@alex</div>

            <div class="mb-4 overflow-hidden rounded-lg">
              <div class="flex h-8">
                {PHASE_COLORS.map((c) => (
                  <div class="flex flex-1 flex-col items-center justify-center gap-0.5" style={`background: ${c.border}22;`}>
                    <div class="h-1 w-3/4 rounded-full" style={`background: ${c.border}; opacity: 0.8;`} />
                    <div class="text-[7px] font-medium" style={`color: ${c.border}; opacity: 0.7;`}>{c.label}</div>
                  </div>
                ))}
              </div>
            </div>

            <div class="mb-4 flex flex-wrap gap-1.5">
              {HOBBIES.map((h) => (
                <span class="rounded-full bg-slate-800 px-2.5 py-1 text-xs text-slate-300">{h}</span>
              ))}
            </div>

            <div class="mb-4 flex items-center gap-2 rounded-lg bg-slate-800/60 px-3 py-2">
              <span class="text-lg">🌍</span>
              <div>
                <div class="text-xs font-bold text-emerald-400">Renaissance Explorer</div>
                <div class="text-[10px] text-slate-500">interests span every corner of life</div>
              </div>
            </div>

            <div class="mb-3 grid grid-cols-3 gap-2">
              {[
                { val: '5', label: 'phases' },
                { val: '34', label: 'hobbies' },
                { val: '3', label: 'rekindled' },
              ].map((s) => (
                <div class="rounded-lg bg-slate-800 px-2 py-2 text-center">
                  <div class="text-sm font-bold text-emerald-400">{s.val}</div>
                  <div class="text-[9px] text-slate-500">{s.label}</div>
                </div>
              ))}
            </div>

            <div class="h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent" />
            <div class="mt-3 text-right text-[9px] text-slate-600">significanthobbies.com</div>
          </div>
        </div>

        {/* Share action strip */}
        <div class="mt-4 flex w-full max-w-sm items-center justify-between rounded-xl border border-stone-200 bg-white px-4 py-3 shadow-sm">
          <span class="text-xs text-stone-400">Share via</span>
          <div class="flex gap-2">
            {SHARE_BUTTONS.map((btn) => (
              <div
                class="flex cursor-default items-center gap-1 rounded-lg border border-stone-100 bg-stone-50 px-2.5 py-1.5 text-xs font-medium text-stone-600"
                title={btn.label}
              >
                <span>{btn.icon}</span>
                <span class="hidden sm:inline">{btn.label}</span>
              </div>
            ))}
            <div class="flex cursor-default items-center gap-1 rounded-lg border border-stone-100 bg-stone-50 px-2.5 py-1.5 text-xs font-medium text-stone-600">
              <span>⬇</span>
              <span class="hidden sm:inline">PNG</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
