    <div class="flex gap-6 text-sm text-stone-400">
      <a href="/timeline/new" class="transition-colors hover:text-stone-700">Start</a>
      <a href="/hobbies" class="transition-colors hover:text-stone-700">Explore</a>
      <a href="/explore" class="transition-colors hover:text-stone-700">Community</a>
