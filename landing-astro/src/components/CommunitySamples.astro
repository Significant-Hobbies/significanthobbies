---
const samples = [
  {
    title: "Alex's Journey",
    username: 'alex',
    phases: 3,
    img: '/categories/creative-800.webp',
    hobbies: ['LEGO', 'Swimming', 'Photography', 'Guitar', 'Hiking', 'Cooking'],
  },
  {
    title: "Jamie's Creative Path",
    username: 'jamie',
    phases: 3,
    img: '/categories/music-800.webp',
    hobbies: ['Sketching', 'Piano', 'Oil Painting', 'Pottery', 'Digital Art'],
  },
  {
    title: "Morgan's Adventure Log",
    username: 'morgan',
    phases: 3,
    img: '/categories/outdoor-800.webp',
    hobbies: ['Football', 'Chess', 'Yoga', 'Trail Running', 'Meditation'],
  },
];

/* Theme-appropriate OKLCH colors that read well on dark charcoal */
const colors = [
  'oklch(0.82 0.13 88)',   /* gold */
  'oklch(0.72 0.13 150)',  /* sage */
  'oklch(0.78 0.10 200)',  /* slate-blue */
  'oklch(0.70 0.15 50)',   /* amber */
  'oklch(0.80 0.08 320)',  /* mauve */
];
---

<section class="bg-background px-6 py-24 lg:px-12">
  <div class="mx-auto max-w-5xl">
    <div class="mb-10 flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
      <div>
        <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">Community</p>
        <h2 class="text-3xl font-medium text-foreground sm:text-4xl">Real hobby journeys</h2>
        <p class="mt-2 text-muted-foreground">Examples while the community grows — build and share yours.</p>
      </div>
      <a
        href="/find-your-hobby"
        class="text-sm font-semibold text-primary no-underline hover:opacity-80 focus-visible:ring-2 focus-visible:ring-foreground/50 focus-visible:outline-none"
      >
        Find your hobby →
      </a>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        samples.map((sample) => (
          <a
            href={`/u/${sample.username}`}
            class="spotlight-card card-lift shadow-elevated group block overflow-hidden rounded-2xl border border-border bg-card no-underline"
          >
            {/* Header image — top 40% with gradient overlay */}
            <div class="relative h-40 overflow-hidden">
              <img
                src={sample.img}
                alt={sample.title}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div
                class="absolute inset-0"
                style="background: linear-gradient(to top, oklch(0.19 0.006 285) 0%, oklch(0.19 0.006 285 / 0.4) 50%, transparent 100%);"
              />
              {/* Phase color stripe at top */}
              <div class="absolute top-0 flex h-1 w-full overflow-hidden">
                {Array.from({ length: sample.phases }).map((_, pi) => (
                  <div class="flex-1" style={`background: ${colors[pi % colors.length]}`} />
                ))}
              </div>
            </div>
            {/* Body */}
            <div class="p-5">
              <h3 class="mb-0.5 font-semibold text-foreground">{sample.title}</h3>
              <p class="mb-3 text-xs text-muted-foreground">@{sample.username}</p>
              <div class="flex flex-wrap gap-1">
                {sample.hobbies.slice(0, 6).map((h) => (
                  <span class="rounded-full border border-border bg-muted px-2 py-0.5 text-[10px] text-muted-foreground">
                    {h}
                  </span>
                ))}
              </div>
              <p class="mt-4 text-xs font-semibold text-primary opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                View journey →
              </p>
            </div>
          </a>
        ))
      }
    </div>

    <div class="mt-10 text-center">
      <a
        href="/timeline/new"
        class="inline-flex rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground no-underline hover:opacity-90 focus-visible:ring-2 focus-visible:ring-foreground/50 focus-visible:outline-none"
      >
        Build and share yours →
      </a>
    </div>
  </div>
</section>
