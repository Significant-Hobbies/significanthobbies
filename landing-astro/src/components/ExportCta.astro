---
// Export CTA — second dark export-card section, "Share your story
// beautifully". Mirrors ShareProof's two-up layout but with a simpler
// dark card preview (no Renaissance Explorer block, "years" stat
// instead of "rekindled").
const PHASE_COLORS = [
  { bg: '#D1FAE5', border: '#10b981', label: 'Childhood' },
  { bg: '#FEF3C7', border: '#F59E0B', label: 'Teen Years' },
  { bg: '#DBEAFE', border: '#3B82F6', label: 'College' },
  { bg: '#FCE7F3', border: '#EC4899', label: 'Early Career' },
  { bg: '#EDE9FE', border: '#8B5CF6', label: 'Now' },
];

const HOBBIES = ['guitar 🎸', 'chess ♟', 'hiking 🏔', 'reading 📚', 'pottery 🏺', 'swimming 🏊'];

const STATS = [
  { val: '5', label: 'phases' },
  { val: '34', label: 'hobbies' },
  { val: '22', label: 'years' },
];
---

<section class="px-4 py-24" style="background: linear-gradient(135deg, #FAFAF9 0%, #F0FDF4 50%, #FAFAF9 100%);">
  <div class="mx-auto max-w-5xl">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
      {/* Left: text */}
      <div class="scroll-reveal-left">
        <span class="mb-4 inline-block rounded-full border border-emerald-200 bg-emerald-50 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-emerald-700">
          Export
        </span>
        <h2 class="mb-4 text-3xl font-bold leading-tight text-stone-900 sm:text-4xl">
          Share your story<br />
          <span class="italic text-emerald-600">beautifully</span>
        </h2>
        <p class="mb-8 text-lg text-stone-500">
          Generate a stunning card of your hobby journey. One click, ready to share anywhere.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/timeline/new"
            class="animate-glow-pulse inline-flex h-11 items-center justify-center rounded-md bg-emerald-600 px-8 text-base font-medium text-white hover:bg-emerald-700"
          >
            Start for free
          </a>
          <a
            href="/hobbies"
            class="inline-flex h-11 items-center justify-center rounded-md border border-stone-300 bg-transparent px-8 text-base font-medium text-stone-600 hover:text-stone-900"
          >
            Browse hobbies
          </a>
        </div>
        <p class="mt-4 text-sm text-stone-400">No sign-up required. Always free.</p>
      </div>

      {/* Right: dark export card preview */}
      <div class="flex justify-center lg:justify-end scroll-reveal-right scroll-reveal-d1">
        <div
          class="animate-float relative w-full max-w-sm overflow-hidden rounded-2xl border border-emerald-900/30 bg-slate-900 p-7 shadow-2xl"
          style="box-shadow: 0 0 40px rgba(16,185,129,0.2), 0 24px 64px rgba(0,0,0,0.3);"
        >
          {/* Shine pass */}
          <div class="pointer-events-none absolute inset-0 overflow-hidden rounded-2xl" style="z-index: 10;">
            <div style="position: absolute; top: 0; left: -100%; width: 60%; height: 100%; background: linear-gradient(105deg, transparent 30%, rgba(255,255,255,0.06) 50%, transparent 70%); animation: shinePass 4s 1s ease-in-out infinite;" />
          </div>

          <div class="relative z-0">
            <div class="mb-1 text-xs font-semibold tracking-widest text-emerald-400 uppercase">My Hobby Journey</div>
            <div class="mb-4 text-lg font-bold text-white">A Life in Hobbies</div>

            <div class="mb-4 overflow-hidden rounded-lg">
              <div class="flex h-8">
                {PHASE_COLORS.map((c) => (
                  <div class="flex flex-1 items-center justify-center" style={`background: ${c.border}22;`}>
                    <div class="h-1.5 w-3/4 rounded-full" style={`background: ${c.border}; opacity: 0.8;`} />
                  </div>
                ))}
              </div>
            </div>

            <div class="mb-5 flex flex-wrap gap-1.5">
              {HOBBIES.map((h) => (
                <span class="rounded-full bg-slate-800 px-2.5 py-1 text-xs text-slate-300">{h}</span>
              ))}
            </div>

            <div class="mb-4 grid grid-cols-3 gap-2">
              {STATS.map((s) => (
                <div class="rounded-lg bg-slate-800 px-2 py-2 text-center">
                  <div class="text-sm font-bold text-emerald-400">{s.val}</div>
                  <div class="text-[9px] text-slate-500">{s.label}</div>
                </div>
              ))}
            </div>

            <div class="h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent" />
            <div class="mt-3 text-right text-[9px] text-slate-600">significanthobbies.com</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
