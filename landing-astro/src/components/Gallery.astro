---
// Community Gallery — three demo timeline cards.
//
// PRODUCT NOTE: the original `page.tsx` reads `getDemoTimelines()`
// from Turso at request time and falls back to `SAMPLE_DEMO_TIMELINES`
// when none are public yet. The static port hard-codes the three
// curated sample journeys instead — they're pitch material, not live
// data, and decoupling this build from `src/lib` keeps the Pages
// project from needing DB access. Update these inline when curation
// changes (see README → "Hard-coded demo timelines").
const CARD_BORDER_COLORS = [
  '#10b981',
  '#F59E0B',
  '#3B82F6',
  '#EC4899',
  '#8B5CF6',
];

const SAMPLE_TIMELINES = [
  {
    title: "Alex's Hobby Journey",
    username: 'alex',
    phases: [
      { name: 'Childhood', hobbies: ['LEGO', 'Cycling', 'Swimming'] },
      { name: 'College', hobbies: ['Photography', 'Guitar', 'Hiking'] },
      { name: 'Now', hobbies: ['Rock Climbing', 'Cooking', 'Reading'] },
    ],
  },
  {
    title: "Jamie's Creative Path",
    username: 'jamie',
    phases: [
      { name: 'Teen Years', hobbies: ['Sketching', 'Piano'] },
      { name: 'Early Career', hobbies: ['Oil Painting', 'Pottery', 'Ceramics'] },
      { name: 'Now', hobbies: ['Digital Art', 'Illustration', 'Photography'] },
    ],
  },
  {
    title: "Morgan's Adventure Log",
    username: 'morgan',
    phases: [
      { name: 'Childhood', hobbies: ['Football', 'Swimming', 'Chess'] },
      { name: 'College', hobbies: ['Hiking', 'Photography', 'Yoga'] },
      { name: 'Now', hobbies: ['Trail Running', 'Rock Climbing', 'Meditation'] },
    ],
  },
];
---

<section class="border-y border-stone-200/60 px-4 py-20" style="background: #FAFAFA;">
  <div class="mx-auto max-w-5xl">
    <div class="mb-10 flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end scroll-reveal">
      <div>
        <span class="mb-2 inline-block rounded-full border border-stone-200 bg-stone-50 px-4 py-1 text-xs font-semibold uppercase tracking-widest text-stone-500">
          Community
        </span>
        <h2 class="text-2xl font-bold text-stone-900 sm:text-3xl">Real hobby journeys</h2>
        <p class="mt-1 text-stone-500">Shared by curious people like you</p>
      </div>
      <a
        href="/hobbies"
        class="inline-flex h-8 items-center justify-center rounded-md px-3 text-sm font-medium text-emerald-600 hover:text-emerald-700"
      >
        Explore all →
      </a>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {SAMPLE_TIMELINES.map((sample, idx) => {
        const borderColor = CARD_BORDER_COLORS[idx % CARD_BORDER_COLORS.length] ?? '#10b981';
        const allHobbies = sample.phases.flatMap((p) => p.hobbies);
        const totalHobbies = new Set(allHobbies).size;
        const revealDelay = idx === 0 ? '' : idx === 1 ? 'scroll-reveal-d2' : 'scroll-reveal-d3';
        return (
          <div
            class={`relative overflow-hidden rounded-2xl border border-stone-200 bg-white opacity-80 shadow-sm scroll-reveal ${revealDelay}`}
            style={`border-left-width: 4px; border-left-color: ${borderColor};`}
          >
            <div class="absolute right-3 top-3 rounded-full bg-stone-100 px-2 py-0.5 text-[9px] font-semibold uppercase tracking-wider text-stone-400">
              Sample
            </div>

            <div class="flex h-1.5 overflow-hidden">
              {sample.phases.map((_, pi) => (
                <div
                  class="flex-1"
                  style={`background: ${CARD_BORDER_COLORS[pi % CARD_BORDER_COLORS.length]};`}
                />
              ))}
            </div>

            <div class="p-5">
              <h3 class="mb-0.5 font-semibold text-stone-800">{sample.title}</h3>
              <p class="mb-3 text-xs text-stone-400">@{sample.username}</p>

              <div class="mb-3 flex items-center gap-2">
                <div class="flex flex-1 gap-0.5 overflow-hidden rounded-full">
                  {sample.phases.map((_, pi) => (
                    <div
                      class="h-1.5 flex-1 rounded-full"
                      style={`background: ${CARD_BORDER_COLORS[pi % CARD_BORDER_COLORS.length]}; opacity: 0.6;`}
                    />
                  ))}
                </div>
                <span class="shrink-0 text-[10px] text-stone-400">
                  {sample.phases.length} phases · {totalHobbies} hobbies
                </span>
              </div>

              <div class="flex flex-wrap gap-1">
                {allHobbies.slice(0, 6).map((h) => (
                  <span class="rounded-full border border-stone-100 bg-stone-50 px-2 py-0.5 text-[10px] text-stone-500">
                    {h}
                  </span>
                ))}
                {totalHobbies > 6 && (
                  <span class="rounded-full border border-stone-100 bg-stone-50 px-2 py-0.5 text-[10px] text-stone-400">
                    +{totalHobbies - 6} more
                  </span>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <div class="mt-8 flex flex-col items-center gap-3 text-center">
      <p class="text-sm text-stone-500">These are examples — explore real timelines once people share theirs.</p>
      <a
        href="/timeline/new"
        class="inline-flex h-9 items-center justify-center rounded-md bg-emerald-600 px-4 text-sm font-medium text-white hover:bg-emerald-700"
      >
        Build and share yours →
      </a>
    </div>
  </div>
</section>
