---
const steps = [
  {
    num: '01',
    title: 'Add your life phases',
    desc: 'Name each chapter: Childhood, College, First Job, whatever feels right.',
  },
  {
    num: '02',
    title: 'Tag every hobby you remember',
    desc: 'Even the ones you only tried once. Swimming at six, pottery last winter.',
  },
  {
    num: '03',
    title: 'Share your journey',
    desc: 'Export a card, publish a public timeline, or keep it private while you explore.',
  },
];

const phaseInputs = [
  { label: 'Phase name', value: 'Childhood', color: 'oklch(0.72 0.13 150)' },
  { label: 'Age range', value: '5 – 12', color: 'oklch(0.72 0.13 150)' },
  { label: 'Phase name', value: 'Teen Years', color: 'oklch(0.82 0.13 88)' },
  { label: 'Age range', value: '13 – 18', color: 'oklch(0.82 0.13 88)' },
];

const addingPills = [
  { text: 'Guitar', color: 'oklch(0.82 0.13 88)', bg: 'oklch(0.82 0.13 88 / 0.12)', border: 'oklch(0.82 0.13 88 / 0.35)' },
  { text: 'Skateboarding', color: 'oklch(0.82 0.13 88)', bg: 'oklch(0.82 0.13 88 / 0.12)', border: 'oklch(0.82 0.13 88 / 0.35)' },
  { text: 'Video games', color: 'oklch(0.82 0.13 88)', bg: 'oklch(0.82 0.13 88 / 0.12)', border: 'oklch(0.82 0.13 88 / 0.35)' },
];

const shareButtons = ['Copy link', 'Export PNG', 'Publish'];
---

<section class="relative border-y border-border bg-card px-6 py-24 lg:px-12">
  <div class="grid-bg pointer-events-none absolute inset-0" aria-hidden="true" />
  <div class="relative mx-auto max-w-5xl">
    <div class="mb-14 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">How it works</p>
      <h2 class="text-3xl font-medium text-foreground sm:text-4xl">Three steps. Under five minutes.</h2>
      <p class="mx-auto mt-3 max-w-xl text-muted-foreground">
        No template police. You can't really get this wrong.
      </p>
    </div>

    <!-- Steps with connecting line on desktop -->
    <div class="relative grid gap-8 md:grid-cols-3">
      <!-- Connecting horizontal line (desktop only) -->
      <div
        class="pointer-events-none absolute left-0 right-0 top-[88px] hidden h-px md:block"
        style="background: linear-gradient(to right, transparent, oklch(0.82 0.13 88 / 0.3), oklch(0.82 0.13 88 / 0.3), transparent);"
        aria-hidden="true"
      />

      {
        steps.map((step, i) => (
          <li class="spotlight-card card-lift shadow-elevated list-none overflow-hidden rounded-2xl border border-border bg-background p-6">
            <!-- Large faded step number -->
            <span
              class="font-serif text-5xl font-semibold"
              style="color: oklch(0.82 0.13 88 / 0.25); line-height: 1;"
            >
              {step.num}
            </span>
            <h3 class="mt-3 text-lg font-semibold text-foreground">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{step.desc}</p>

            {/* ─── Visual mockup per step ─── */}
            {i === 0 && (
              <div class="mt-5 rounded-xl border border-border bg-card p-4">
                <p class="mb-3 text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">
                  Phase input
                </p>
                <div class="flex flex-col gap-2.5">
                  {phaseInputs.map((input) => (
                    <div>
                      <label class="mb-1 block text-[10px] text-muted-foreground">{input.label}</label>
                      <div
                        class="flex items-center justify-between rounded-md border bg-background px-2.5 py-1.5 text-[11px]"
                        style={`border-color: ${input.color.replace(')', ' / 0.35)')}`}
                      >
                        <span class="text-foreground">{input.value}</span>
                        <div class="h-2 w-2 rounded-full" style={`background: ${input.color}`} />
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {i === 1 && (
              <div class="mt-5 rounded-xl border border-border bg-card p-4">
                <p class="mb-3 text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">
                  Add hobbies to Teen Years
                </p>
                <div class="flex flex-wrap gap-1.5">
                  {addingPills.map((pill) => (
                    <span
                      class="rounded-full border px-2 py-0.5 text-[11px] font-medium"
                      style={`background: ${pill.bg}; border-color: ${pill.border}; color: ${pill.color}`}
                    >
                      {pill.text}
                    </span>
                  ))}
                  <span class="rounded-full border border-dashed border-border px-2 py-0.5 text-[11px] text-muted-foreground">
                    + add hobby
                  </span>
                </div>
              </div>
            )}

            {i === 2 && (
              <div class="mt-5 rounded-xl border border-border bg-card p-4">
                <p class="mb-3 text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">
                  Export &amp; share
                </p>
                <div class="gradient-border mb-3 p-3">
                  <div class="flex items-center gap-2">
                    <div class="flex h-6 w-6 items-center justify-center rounded-full bg-primary text-[10px] font-bold text-primary-foreground">
                      A
                    </div>
                    <span class="text-[11px] font-semibold text-foreground">@alex · 5 hobbies</span>
                  </div>
                </div>
                <div class="flex flex-wrap gap-1.5">
                  {shareButtons.map((btn) => (
                    <span class="rounded-md border border-border bg-background px-2 py-1 text-[10px] font-medium text-foreground">
                      {btn}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </li>
        ))
      }
    </div>

    <div class="mt-12 text-center">
      <a
        href="/timeline/new"
        class="shadow-glow inline-flex rounded-full bg-primary px-7 py-3 text-sm font-semibold text-primary-foreground no-underline transition-opacity hover:opacity-90 focus-visible:ring-2 focus-visible:ring-foreground/50 focus-visible:outline-none"
      >
        Start your hobby map →
      </a>
    </div>
  </div>
</section>
