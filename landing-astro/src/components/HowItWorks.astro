---
const steps = [
  {
    num: '01',
    title: 'Add your life phases',
    desc: 'Name each chapter — Childhood, College, First Job, whatever feels right.',
  },
  {
    num: '02',
    title: 'Tag every hobby you remember',
    desc: 'Even the ones you only tried once. Swimming at six, pottery last winter.',
  },
  {
    num: '03',
    title: 'Share your journey',
    desc: 'Export a card, publish a public timeline, or keep it private while you explore.',
  },
];
---

<section class="bg-white px-6 py-24 lg:px-12">
  <div class="mx-auto max-w-5xl">
    <h2 class="text-center text-2xl font-bold text-stone-900 sm:text-3xl">How it works</h2>
    <p class="mx-auto mt-2 max-w-xl text-center text-stone-500">
      Three steps. No template police. Start in under five minutes.
    </p>
    <ol class="mt-12 grid gap-8 md:grid-cols-3">
      {
        steps.map((step) => (
          <li class="rounded-2xl border border-stone-100 bg-stone-50 p-6">
            <p class="font-mono text-xs text-emerald-600">{step.num}</p>
            <h3 class="mt-2 text-lg font-bold text-stone-900">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-500">{step.desc}</p>
          </li>
        ))
      }
    </ol>
    <div class="mt-10 text-center">
      <a
        href="/timeline/new"
        class="inline-flex rounded-full bg-emerald-500 px-7 py-3 text-sm font-semibold text-white no-underline transition-colors hover:bg-emerald-400"
      >
        Start your hobby map →
      </a>
    </div>
  </div>
</section>