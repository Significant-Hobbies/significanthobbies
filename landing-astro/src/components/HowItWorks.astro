---
const steps = [
  {
    title: 'Add your life phases',
    desc: 'Name each chapter — Childhood, College, First Job, whatever feels right.',
  },
  {
    title: 'Tag every hobby you remember',
    desc: 'Even the ones you only tried once. Swimming at six, pottery last winter.',
  },
  {
    title: 'Share your journey',
    desc: 'Export a card, publish a public timeline, or keep it private while you explore.',
  },
];
---

<section class="relative bg-card border-y border-border px-6 py-24 lg:px-12">
  <div class="grid-bg pointer-events-none absolute inset-0" aria-hidden="true" />
  <div class="relative mx-auto max-w-5xl">
    <h2 class="text-center text-2xl font-medium text-foreground sm:text-3xl">How it works</h2>
    <p class="mx-auto mt-2 max-w-xl text-center text-muted-foreground">
      Three steps. No template police. Start in under five minutes.
    </p>
    <ol class="mt-12 grid gap-8 md:grid-cols-3">
      {
        steps.map((step) => (
          <li class="spotlight-card rounded-2xl border border-border bg-background p-6">
            <h3 class="text-lg font-semibold text-foreground">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{step.desc}</p>
          </li>
        ))
      }
    </ol>
    <div class="mt-10 text-center">
      <a
        href="/timeline/new"
        class="inline-flex rounded-full bg-primary px-7 py-3 text-sm font-semibold text-primary-foreground no-underline transition-opacity hover:opacity-90 focus-visible:ring-2 focus-visible:ring-foreground/50 focus-visible:outline-none"
      >
        Start your hobby map →
      </a>
    </div>
  </div>
</section>
