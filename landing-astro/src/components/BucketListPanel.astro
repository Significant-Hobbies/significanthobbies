---
const famous = [
  { name: 'Will Smith', emoji: '🎬', slug: 'will-smith' },
  { name: 'Obama', emoji: '🇺🇸', slug: 'barack-obama' },
  { name: 'Serena', emoji: '🎾', slug: 'serena-williams' },
  { name: 'Musk', emoji: '🚀', slug: 'elon-musk' },
  { name: 'Branson', emoji: '🎈', slug: 'richard-branson' },
  { name: 'Zuckerberg', emoji: '💻', slug: 'mark-zuckerberg' },
];
---

<section class="px-6 py-24 lg:px-12" style="background: #c94420">
  <div class="mx-auto max-w-4xl text-center">
    <p class="mb-6 text-5xl" aria-hidden="true">🦊</p>
    <h2 class="text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
      What will you do before you die?
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-white/80">
      Twelve remarkable people wrote theirs down. Browse their bucket lists — then build yours.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-2">
      {
        famous.map((person) => (
          <a
            href={`/bucket-lists/${person.slug}`}
            class="rounded-full border border-white/30 px-4 py-1.5 text-sm text-white/90 no-underline transition hover:bg-white/10"
          >
            {person.emoji} {person.name}
          </a>
        ))
      }
    </div>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a
        href="/bucket-lists"
        class="rounded-full bg-white px-7 py-3 text-sm font-semibold text-[#c94420] no-underline transition hover:bg-white/90"
      >
        Browse famous bucket lists →
      </a>
      <a
        href="/bucket-list-ideas"
        class="rounded-full border border-white/40 px-7 py-3 text-sm font-semibold text-white no-underline transition hover:bg-white/10"
      >
        150+ ideas →
      </a>
    </div>
  </div>
</section>