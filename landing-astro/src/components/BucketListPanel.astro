---
const famous = [
  {
    name: 'Will Smith',
    slug: 'will-smith',
    img: '/categories/creative-800.webp',
    preview: 'Skydive over the Dubai desert',
  },
  {
    name: 'Barack Obama',
    slug: 'barack-obama',
    img: '/categories/intellectual-800.webp',
    preview: 'Visit every US national park',
  },
  {
    name: 'Serena Williams',
    slug: 'serena-williams',
    img: '/categories/physical-800.webp',
    preview: 'Start a foundation for girls',
  },
  {
    name: 'Elon Musk',
    slug: 'elon-musk',
    img: '/categories/making-800.webp',
    preview: 'See Earth from space',
  },
  {
    name: 'Richard Branson',
    slug: 'richard-branson',
    img: '/categories/outdoor-800.webp',
    preview: 'Cross the Atlantic in a balloon',
  },
  {
    name: 'Mark Zuckerberg',
    slug: 'mark-zuckerberg',
    img: '/categories/gaming-800.webp',
    preview: 'Learn Mandarin fluently',
  },
];
---

<section class="border-y border-border bg-card px-6 py-24 lg:px-12">
  <div class="mx-auto max-w-6xl">
    <!-- Centered heading -->
    <div class="mx-auto mb-14 max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">Bucket lists</p>
      <h2 class="text-3xl font-medium text-foreground sm:text-4xl lg:text-5xl" style="line-height: 1.1;">
        What will you do before you die?
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-muted-foreground">
        Twelve remarkable people wrote theirs down. Browse their bucket lists — then build yours.
      </p>
    </div>

    <!-- 6 celebrity cards: 3 cols × 2 rows -->
    <div class="grid grid-cols-2 gap-5 md:grid-cols-3">
      {
        famous.map((person) => (
          <a
            href={`/bucket-lists/${person.slug}`}
            class="card-lift group relative block overflow-hidden rounded-2xl border border-border bg-background"
            style="aspect-ratio: 4 / 5;"
          >
            <img
              src={person.img}
              alt={`${person.name} — bucket list`}
              loading="lazy"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <!-- Dark gradient overlay -->
            <div
              class="absolute inset-0"
              style="background: linear-gradient(to top, oklch(0.15 0.005 285 / 0.95) 0%, oklch(0.15 0.005 285 / 0.5) 45%, oklch(0.15 0.005 285 / 0.15) 100%);"
            />
            <!-- Bottom content -->
            <div class="absolute inset-x-0 bottom-0 p-5">
              <h3 class="font-serif text-lg font-semibold text-foreground">{person.name}</h3>
              <p class="mt-1 text-xs text-muted-foreground" style="line-height: 1.4;">
                "{person.preview}"
              </p>
              <span class="mt-3 inline-flex items-center gap-1 text-xs font-semibold text-primary opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                View bucket list →
              </span>
            </div>
          </a>
        ))
      }
    </div>

    <!-- CTAs -->
    <div class="mt-12 flex flex-wrap justify-center gap-4">
      <a
        href="/bucket-lists"
        class="rounded-full bg-primary px-7 py-3 text-sm font-semibold text-primary-foreground no-underline transition-opacity hover:opacity-90 focus-visible:ring-2 focus-visible:ring-foreground/50 focus-visible:outline-none"
      >
        Browse famous bucket lists →
      </a>
      <a
        href="/bucket-list-ideas"
        class="rounded-full border border-border px-7 py-3 text-sm font-semibold text-foreground no-underline transition-colors hover:border-muted-foreground focus-visible:ring-2 focus-visible:ring-foreground/50 focus-visible:outline-none"
      >
        150+ ideas →
      </a>
    </div>
  </div>
</section>
